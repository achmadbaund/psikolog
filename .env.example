# ====================================
# ENVIRONMENT VARIABLES TEMPLATE
# ====================================

# ⚠️ PILIH SALAH SATU BERDASARKAN ENVIRONMENT ANDA:

# 1. LOCAL DOCKER DEVELOPMENT:
#    Copy dari .env.docker
#    cp .env.docker .env

# 2. RENDER.COM PRODUCTION:
#    TIDAK PERLU .env file!
#    Render akan AUTO-FILL dari render.yaml
#    Lihat .env.render untuk referensi saja

# ====================================
# LOCAL DOCKER - COPY INI KE .env
# ====================================
# Jalankan: cp .env.docker .env

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=psikolog_db
FASKES_SERVICE_URL=http://faskes-service:8009
NODE_ENV=development
PORT=8003
CORS_ORIGIN=*

# ====================================
# RENDER.COM - JANGAN DIBUAT .env
# ====================================
# Render akan otomatis mengisi ini dari render.yaml:
#
# DB_HOST = auto-fill dari PostgreSQL service
# DB_PORT = auto-fill dari PostgreSQL service
# DB_USER = auto-fill dari PostgreSQL service
# DB_PASSWORD = auto-fill dari PostgreSQL service
# DB_NAME = psikolog_db
#
# Manual set di Render dashboard:
# FASKES_SERVICE_URL=https://psikolog-faskes-service.onrender.com
# NODE_ENV=production
# PORT=8003

# ====================================
# OPTIONAL VARIABLES
# ====================================
# BPJS_API_KEY=your_bpjs_api_key_here
# ALLO_BANK_API_KEY=your_allo_bank_api_key_here
# JWT_SECRET=your_jwt_secret_here_change_in_production
