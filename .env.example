# Database Configuration (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=psikolog_db

# Faskes Service URL (Internal Docker Network)
FASKES_SERVICE_URL=http://faskes-service:8009

# Application Configuration
NODE_ENV=development
PORT=8003

# External API URLs (Optional)
BPJS_API_URL=https://api.bpjs-kesehatan.go.id
ALLO_BANK_API_URL=https://api.allobank.com

# API Keys (Optional - untuk production)
BPJS_API_KEY=your_bpjs_api_key_here
ALLO_BANK_API_KEY=your_allo_bank_api_key_here

# JWT Secret (Optional - untuk authentication)
JWT_SECRET=your_jwt_secret_here_change_in_production

# CORS Configuration (Optional)
CORS_ORIGIN=http://localhost:3000
